{
  "name": "chess-server",
  "version": "1.0.0",
  "description": "Chess server with authentication and game history",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "postinstall": "prisma generate",
    "build": "prisma generate && tsc",
    "start": "node dist/src/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed:puzzles": "node prisma/seedPuzzles.js",
    "loadtest:ws": "tsx load-tests/ws-load-test.ts",
    "loadtest:rest": "tsx load-tests/rest-load-test.ts",
    "loadtest": "npm run loadtest:rest && npm run loadtest:ws"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "chess.js": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.22.0",
    "redis": "^4.7.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/autocannon": "^7.12.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.19.43",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "autocannon": "^8.0.0",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.4.5"
  }
}
